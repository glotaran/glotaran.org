---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import SiteNav from '../components/SiteNav.astro';

const packages = (await getCollection('software'))
  .sort((a, b) => a.data.order - b.data.order);

const publications = (await getCollection('publications'))
  .sort((a, b) => b.data.year - a.data.year);

const langLabel: Record<string, string> = { python: 'Python', r: 'R', java: 'Java' };
const flagship = packages.find((p) => p.slug === 'pyglotaran')!;
const rest = packages.filter((p) => p.slug !== 'pyglotaran');
const base = import.meta.env.BASE_URL;
---

<Base>
  <!-- Spectrum bar -->
  <div class="spectrum-bar"></div>

  <!-- Nav -->
  <SiteNav isHome communityHref="#community" />

  <!-- Hero -->
  <div class="hero">
    <div class="hero-eyebrow">Open-source · Global &amp; Target Analysis · Time-resolved · Spectroscopy · FLIM · Multi-way Data</div>
    <h1>Modeling frameworks<br />for <em>separable</em> data</h1>
    <p class="hero-sub">
      Open-source tools for global and target analysis of time-resolved spectroscopy,
      fluorescence lifetime imaging, and multi-way data — from photosynthesis and
      photovoltaics to photochemistry and beyond.
    </p>
    <div class="hero-actions">
      <a href={`${base}software/pyglotaran`} class="btn-primary">Get started with pyglotaran</a>
      <a href={`${base}ecosystem`} class="btn-ghost">Explore the ecosystem</a>
    </div>
    <div class="install-block">
      <span class="prefix">$</span>
      <span class="cmd">pip install pyglotaran pyglotaran-extras</span>
      <button
        class="install-copy"
        onclick="navigator.clipboard.writeText('pip install pyglotaran pyglotaran-extras')"
      >copy</button>
    </div>

    <div style="margin-top: 3rem;">
      <div style="display:flex;justify-content:center;">
        <div class="spectrum-swatch"></div>
      </div>
      <div class="spectrum-ticks">
        <span class="spectrum-tick">350 nm</span>
        <span class="spectrum-tick">450 nm</span>
        <span class="spectrum-tick">550 nm</span>
        <span class="spectrum-tick">650 nm</span>
        <span class="spectrum-tick">750 nm</span>
      </div>
    </div>
  </div>

  <div class="divider"></div>

  <!-- Heritage timeline -->
  <section class="timeline">
    <div class="timeline-track">
      <div class="timeline-stop">
        <span class="timeline-year">2007</span>
        <span class="timeline-name">TIMP</span>
        <span class="timeline-note">R engine for partitioned variable projection</span>
      </div>
      <div class="timeline-line"></div>
      <div class="timeline-stop">
        <span class="timeline-year">2012</span>
        <span class="timeline-name">Glotaran</span>
        <span class="timeline-note">Java desktop interface for TIMP</span>
      </div>
      <div class="timeline-line"></div>
      <div class="timeline-stop">
        <span class="timeline-year">2023</span>
        <span class="timeline-name">pyglotaran</span>
        <span class="timeline-note">Modern Python framework — the flagship</span>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- Ecosystem section -->
  <section id="ecosystem">
    <p class="pull-quote"><em>Decompose your data. Discover your kinetics.</em></p>
    <div class="section-label">Packages</div>
    <div class="section-title">The <em>ecosystem</em></div>

    <!-- Featured: pyglotaran -->
    <div class="featured-card">
      <div>
        <div class="featured-overline">
          <span class="featured-tag flagship">Flagship</span>
          <span class="featured-tag">Python</span>
        </div>
        <h2>pyglotaran</h2>
        <p>
          Build kinetic models for your time-resolved data in Python.
          Describe your model in YAML, fit it with partitioned variable projection, and
          visualise publication-ready results — all within a Jupyter notebook.
        </p>
        <ul class="feature-list">
          <li>Partitioned variable projection for efficient fitting</li>
          <li>Analyse multiple datasets simultaneously</li>
          <li>Extend with custom kinetic and spectral models</li>
          <li>Jupyter-native, built on NumPy and xarray</li>
          <li>Cross-validated against two decades of TIMP results</li>
        </ul>
      </div>
      <div class="code-block">
        <span class="tok-comment"># minimal target analysis</span><br />
        <span class="tok-keyword">import</span> <span class="tok-import">pyglotaran</span> <span class="tok-keyword">as</span> <span class="tok-var">pg</span><br />
        <br />
        <span class="tok-var">model</span>  = <span class="tok-fn">pg.read_model_from_yaml</span>(<span class="tok-string">"model.yaml"</span>)<br />
        <span class="tok-var">data</span>   = <span class="tok-fn">pg.load_dataset</span>(<span class="tok-string">"measurement.sdt"</span>)<br />
        <br />
        <span class="tok-var">scheme</span> = <span class="tok-fn">pg.Scheme</span>(<br />
        &nbsp;&nbsp;&nbsp;&nbsp;model=<span class="tok-var">model</span>,<br />
        &nbsp;&nbsp;&nbsp;&nbsp;data=&#123;<span class="tok-string">"data_1"</span>: <span class="tok-var">data</span>&#125;,<br />
        )<br />
        <br />
        <span class="tok-var">result</span> = <span class="tok-fn">pg.optimize</span>(<span class="tok-var">scheme</span>)<br />
        <span class="tok-var">result</span>.<span class="tok-fn">save</span>(<span class="tok-string">"result/"</span>)
      </div>
    </div>

    <!-- Package grid — driven by src/content/packages/ -->
    <div class="ecosystem-grid">
      {rest.map((pkg) => (
        <a href={`${base}software/${pkg.slug}`} class={`pkg-card ${pkg.data.lang}`}>
          <div class="pkg-header">
            <span class="pkg-name">{pkg.data.name}</span>
            <span class="pkg-arrow">↗</span>
          </div>
          <span class={`pkg-lang ${pkg.data.status === 'archived' ? 'archived' : pkg.data.lang}`}>
            {langLabel[pkg.data.lang]}{pkg.data.status === 'archived' ? ' · Archived' : ''}
          </span>
          <p class="pkg-desc">{pkg.data.summary}</p>
          <div class="pkg-meta">
            {pkg.data.badges.map((b) => <span class="pkg-badge">{b}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>

  <div class="divider"></div>

  <!-- Publications -->
  <section id="publications">
    <p class="pull-quote"><em>From time-resolved spectra to kinetic models and species spectra you can interpret.</em></p>
    <div class="section-label">Literature</div>
    <div class="section-title"><em>Cite</em> the work</div>

    <div class="pub-grid">
      {publications.map((pub) => (
        <div class="pub-card">
          <span class="pub-year">{pub.data.year}</span>
          <div>
            <div class="pub-title">{pub.data.title}</div>
            <div class="pub-authors">{pub.data.authors}</div>
            <div class="pub-journal">{pub.data.journal}{pub.data.doi ? ` · DOI: ${pub.data.doi}` : ''}</div>
          </div>
          <div class="pub-links">
            {pub.data.doi && (
              <a href={`https://doi.org/${pub.data.doi}`} class="pub-link" target="_blank" rel="noopener">DOI ↗</a>
            )}
            {pub.data.bib && (
              <a href={`/bib/${pub.data.bib}`} class="pub-link" download>BibTeX</a>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <div class="divider"></div>

  <!-- Community -->
  <section id="community">
    <div class="section-label">Community</div>
    <div class="section-title">Get <em>help</em>, contribute</div>
    <p class="section-intro">
      Whether you are fitting your first decay or building custom megacomplexes,
      you are welcome here. Ask questions, share results, or help improve the code.
    </p>

    <div class="community-grid">
      <a href="https://discord.gg/KfnEYRSTJx" class="community-card" target="_blank" rel="noopener">
        <div class="community-icon">💬</div>
        <div class="community-name">Discord</div>
        <div class="community-desc">Real-time chat for questions, announcements, and discussion.</div>
      </a>
      <a href="https://github.com/glotaran" class="community-card" target="_blank" rel="noopener">
        <div class="community-icon">⬡</div>
        <div class="community-name">GitHub</div>
        <div class="community-desc">Source code, issues, and pull requests for all packages.</div>
      </a>
      <a href="https://groups.google.com/forum/#!forum/glotaran" class="community-card" target="_blank" rel="noopener">
        <div class="community-icon">✉</div>
        <div class="community-name">Mailing list</div>
        <div class="community-desc">Google Groups — longer discussions and announcements.</div>
      </a>
      <a href="/publications" class="community-card">
        <div class="community-icon">◈</div>
        <div class="community-name">Publications</div>
        <div class="community-desc">Papers using pyglotaran and TIMP submitted by the community.</div>
      </a>
    </div>
  </section>

  <div class="divider"></div>

  <!-- Footer -->
  <footer>
    <div>
      <div class="footer-logo">GloTarAn</div>
      <div class="footer-copy">
        From photons to insight.<br />
        <span class="nm" title="&quot;What… is your favourite wavelength?&quot;&#10;&quot;532 nm!&quot;&#10;&quot;Right. Off you go.&quot;">
          © Joris Snellenburg &amp; contributors · VU Amsterdam
        </span> 
      </div>
    </div>
    <div class="footer-links">
      <a href="https://github.com/glotaran" target="_blank" rel="noopener">GitHub organization</a>
      <a href="https://pyglotaran.readthedocs.io" target="_blank" rel="noopener">pyglotaran docs</a>
      <a href="https://cran.r-project.org/web/packages/TIMP/" target="_blank" rel="noopener">TIMP on CRAN</a>
      <a href="https://zenodo.org/doi/10.5281/zenodo.4534043" target="_blank" rel="noopener">Zenodo DOI</a>
    </div>
  </footer>
</Base>

<style>
  /* ─── SPECTRUM BAR ─── */
  .spectrum-bar {
    height: 3px;
    background: linear-gradient(90deg,
      #9c27b0 0%, #3f51b5 14%, #03a9f4 28%, #00bcd4 38%,
      #4caf50 52%, #cddc39 65%, #ffc107 78%, #ff5722 90%, #f44336 100%
    );
  }

  /* ─── NAV ─── */
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2.5rem;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: rgba(12,14,18,0.92);
    backdrop-filter: blur(12px);
    z-index: 100;
  }
  .nav-logo { display: flex; align-items: baseline; gap: 0.1em; text-decoration: none; }
  .nav-logo-glo { font-family: var(--font-display); font-weight: 600; font-size: 1.4rem; color: var(--text); letter-spacing: -0.02em; }
  .nav-logo-tar { font-family: var(--font-display); font-weight: 300; font-style: italic; font-size: 1.4rem; color: var(--text-muted); }
  .nav-logo-an  { font-family: var(--font-display); font-weight: 600; font-size: 1.4rem; color: var(--text); }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a { color: var(--text-muted); text-decoration: none; font-size: 0.875rem; font-weight: 400; transition: color 0.15s; }
  .nav-links a:hover { color: var(--text); }
  .nav-cta {
    background: transparent; border: 1px solid var(--border-hover);
    color: var(--text); padding: 0.45rem 1.1rem; border-radius: 6px;
    font-size: 0.875rem; font-weight: 400; cursor: pointer;
    transition: border-color 0.15s, background 0.15s; text-decoration: none;
  }
  .nav-cta:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.25); }

  /* ─── HERO ─── */
  .hero { max-width: 900px; margin: 0 auto; padding: 7rem 2.5rem 5rem; text-align: center; }
  .hero-eyebrow {
    display: inline-block; font-family: var(--font-mono); font-size: 0.75rem;
    color: var(--text-dim); letter-spacing: 0.12em; text-transform: uppercase;
    margin-bottom: 1.5rem; padding: 0.35rem 0.9rem;
    border: 1px solid var(--border); border-radius: 100px;
  }
  .hero h1 {
    font-family: var(--font-display); font-size: clamp(2.8rem, 6vw, 4.5rem);
    font-weight: 300; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--text); margin-bottom: 1.5rem;
  }
  .hero h1 em { font-style: italic; font-weight: 300; color: var(--text-muted); }
  .hero-sub { font-size: 1.1rem; color: var(--text-muted); max-width: 600px; margin: 0 auto 3rem; font-weight: 300; }
  .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 4rem; }
  .btn-primary { background: var(--text); color: var(--bg); padding: 0.7rem 1.8rem; border-radius: 6px; text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: opacity 0.15s; }
  .btn-primary:hover { opacity: 0.85; }
  .btn-ghost { background: transparent; color: var(--text-muted); padding: 0.7rem 1.8rem; border-radius: 6px; border: 1px solid var(--border); text-decoration: none; font-size: 0.9rem; font-weight: 400; transition: color 0.15s, border-color 0.15s; }
  .btn-ghost:hover { color: var(--text); border-color: var(--border-hover); }

  /* ─── INSTALL ─── */
  .install-block { display: inline-flex; align-items: center; gap: 1rem; background: var(--bg-surface); border: 1px solid var(--border); border-radius: 8px; padding: 0.75rem 1.25rem; font-family: var(--font-mono); font-size: 0.82rem; }
  .install-block .prefix { color: var(--text-dim); }
  .install-block .cmd { color: var(--accent-py); }
  .install-copy { background: none; border: 1px solid var(--border); color: var(--text-dim); padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.7rem; cursor: pointer; font-family: var(--font-mono); transition: color 0.15s, border-color 0.15s; }
  .install-copy:hover { color: var(--text); border-color: var(--border-hover); }

  /* ─── SPECTRUM DECORATION ─── */
  .spectrum-swatch { height: 4px; width: 400px; max-width: 100%; border-radius: 2px; background: linear-gradient(90deg, #9c27b0,#3f51b5,#03a9f4,#00bcd4,#4caf50,#cddc39,#ffc107,#ff5722,#f44336); }
  .spectrum-ticks { display: flex; justify-content: space-between; width: 400px; max-width: 100%; margin: 0 auto; padding-top: 0.4rem; }
  .spectrum-tick { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-dim); }

  /* ─── DIVIDER ─── */
  .divider { height: 1px; background: var(--border); max-width: 1100px; margin: 0 auto; }

  /* ─── HERITAGE TIMELINE ─── */
  .timeline { max-width: 800px; margin: 0 auto; padding: 3rem 2.5rem 2rem; }
  .timeline-track { display: flex; align-items: center; justify-content: center; gap: 0; }
  .timeline-stop { display: flex; flex-direction: column; align-items: center; gap: 0.25rem; text-align: center; flex: 0 0 auto; padding: 0 1rem; }
  .timeline-year { font-family: var(--font-mono); font-size: 0.7rem; color: var(--accent-py); letter-spacing: 0.05em; }
  .timeline-name { font-family: var(--font-mono); font-size: 0.85rem; font-weight: 500; color: var(--text); }
  .timeline-note { font-size: 0.75rem; color: var(--text-dim); max-width: 180px; line-height: 1.35; }
  .timeline-line { flex: 1; height: 1px; min-width: 2rem; background: var(--border-hover); }
  @media (max-width: 600px) {
    .timeline-track { flex-direction: column; gap: 0.75rem; }
    .timeline-line { width: 1px; height: 1.5rem; min-width: 0; }
  }

  /* ─── PULL QUOTES ─── */
  .pull-quote { font-family: var(--font-display); font-size: 1.15rem; font-weight: 300; color: var(--text-muted); text-align: center; margin-bottom: 2.5rem; letter-spacing: -0.01em; }

  /* ─── SECTION INTRO ─── */
  .section-intro { font-size: 0.95rem; color: var(--text-muted); margin-bottom: 2rem; max-width: 640px; }

  /* ─── SECTIONS ─── */
  section { max-width: 1100px; margin: 0 auto; padding: 5rem 2.5rem; }
  .section-label { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-dim); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.75rem; }
  .section-title { font-family: var(--font-display); font-size: 2rem; font-weight: 300; letter-spacing: -0.02em; color: var(--text); margin-bottom: 3rem; }
  .section-title em { font-style: italic; color: var(--text-muted); }

  /* ─── FEATURED CARD ─── */
  .featured-card {
    background: var(--bg-card); border: 1px solid var(--border);
    border-top: 2px solid rgba(74,222,128,0.4);
    border-radius: 10px; padding: 2.5rem;
    display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem;
    align-items: start; margin-bottom: 1rem;
  }
  @media (max-width: 680px) { .featured-card { grid-template-columns: 1fr; } }
  .featured-overline { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; }
  .featured-tag { font-family: var(--font-mono); font-size: 0.7rem; font-weight: 500; padding: 0.2rem 0.6rem; border-radius: 4px; background: rgba(74,222,128,0.12); color: var(--accent-py); }
  .featured-tag.flagship { background: rgba(255,213,79,0.1); color: var(--accent-gold); }
  .featured-card h2 { font-family: var(--font-mono); font-size: 1.4rem; font-weight: 500; color: var(--text); margin-bottom: 0.75rem; }
  .featured-card p { font-size: 0.9rem; color: var(--text-muted); margin-bottom: 1.25rem; line-height: 1.6; }
  .feature-list { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
  .feature-list li { font-size: 0.85rem; color: var(--text-muted); padding-left: 1.1rem; position: relative; }
  .feature-list li::before { content: '→'; position: absolute; left: 0; color: var(--accent-py); font-size: 0.8rem; }

  /* ─── CODE BLOCK ─── */
  .code-block { background: var(--bg); border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem 1.5rem; font-family: var(--font-mono); font-size: 0.78rem; line-height: 2; overflow-x: auto; }
  .tok-comment { color: var(--text-dim); }
  .tok-keyword { color: #c792ea; }
  .tok-import  { color: var(--accent-py); }
  .tok-string  { color: #c3e88d; }
  .tok-fn      { color: #82aaff; }
  .tok-var     { color: var(--text); }

  /* ─── ECOSYSTEM GRID ─── */
  .ecosystem-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; }
  .pkg-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; padding: 1.5rem; text-decoration: none; display: flex; flex-direction: column; gap: 0.75rem; transition: border-color 0.2s, transform 0.15s; position: relative; overflow: hidden; }
  .pkg-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; opacity: 0; transition: opacity 0.2s; }
  .pkg-card:hover { border-color: var(--border-hover); transform: translateY(-2px); }
  .pkg-card:hover::before { opacity: 1; }
  .pkg-card.py::before  { background: var(--accent-py); }
  .pkg-card.r::before   { background: var(--accent-r); }
  .pkg-card.java::before { background: var(--accent-java); }
  .pkg-header { display: flex; align-items: center; justify-content: space-between; }
  .pkg-lang { font-family: var(--font-mono); font-size: 0.7rem; padding: 0.2rem 0.55rem; border-radius: 4px; font-weight: 500; }
  .pkg-lang.py  { background: rgba(74,222,128,0.12); color: var(--accent-py); }
  .pkg-lang.r   { background: rgba(117,170,219,0.12); color: var(--accent-r); }
  .pkg-lang.java { background: rgba(248,152,32,0.12); color: var(--accent-java); }
  .pkg-lang.archived { background: rgba(255,255,255,0.05); color: var(--text-dim); }
  .pkg-name { font-family: var(--font-mono); font-size: 0.95rem; font-weight: 500; color: var(--text); }
  .pkg-desc { font-size: 0.85rem; color: var(--text-muted); line-height: 1.5; flex: 1; }
  .pkg-meta { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .pkg-badge { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-dim); background: rgba(255,255,255,0.04); border: 1px solid var(--border); padding: 0.15rem 0.5rem; border-radius: 4px; }
  .pkg-arrow { color: var(--text-dim); font-size: 0.9rem; transition: transform 0.15s; }
  .pkg-card:hover .pkg-arrow { transform: translate(3px, -3px); }

  /* ─── PUBLICATIONS ─── */
  .pub-grid { display: flex; flex-direction: column; gap: 1rem; }
  .pub-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem 1.5rem; display: grid; grid-template-columns: auto 1fr auto; gap: 1rem; align-items: start; }
  .pub-year { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-dim); padding-top: 0.2rem; min-width: 3rem; }
  .pub-title { font-size: 0.9rem; color: var(--text); font-weight: 400; line-height: 1.4; margin-bottom: 0.35rem; }
  .pub-authors { font-size: 0.8rem; color: var(--text-muted); line-height: 1.4; }
  .pub-journal { font-size: 0.78rem; color: var(--text-dim); font-style: italic; margin-top: 0.2rem; }
  .pub-links { display: flex; gap: 0.5rem; flex-direction: column; align-items: flex-end; }
  .pub-link { font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-dim); text-decoration: none; border: 1px solid var(--border); padding: 0.2rem 0.55rem; border-radius: 4px; white-space: nowrap; transition: color 0.15s, border-color 0.15s; }
  .pub-link:hover { color: var(--text); border-color: var(--border-hover); }

  /* ─── COMMUNITY ─── */
  .community-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; }
  .community-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem; text-decoration: none; transition: border-color 0.15s; display: block; }
  .community-card:hover { border-color: var(--border-hover); }
  .community-icon { font-size: 1.4rem; margin-bottom: 0.75rem; }
  .community-name { font-size: 0.9rem; font-weight: 500; color: var(--text); margin-bottom: 0.3rem; }
  .community-desc { font-size: 0.8rem; color: var(--text-muted); line-height: 1.4; }

  /* ─── FOOTER ─── */
  footer { border-top: 1px solid var(--border); padding: 3rem 2.5rem; max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: start; }
