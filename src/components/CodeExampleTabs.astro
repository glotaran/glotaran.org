---
import { Code } from 'astro:components';
import type { ExampleTab } from '../data/pyglotaranExample';

interface Props {
  id: string;
  tabs: ExampleTab[];
  compact?: boolean;
  ariaLabel?: string;
  bundleHref?: string;
  bundleLabel?: string;
  showDownloads?: boolean;
}

const {
  id,
  tabs,
  compact = false,
  ariaLabel = 'Example tabs',
  bundleHref,
  bundleLabel = 'my_project.zip',
  showDownloads = false,
} = Astro.props;

const firstTab = tabs[0];
const baseHref = import.meta.env.BASE_URL;

function resolveHref(href: string) {
  if (href.startsWith('http://') || href.startsWith('https://') || href.startsWith('/')) {
    return href;
  }

  return `${baseHref}${href}`;
}
---

<div class:list={['code-example-tabs', compact && 'compact']} data-code-example-tabs>
  <div class="code-example-toolbar">
    <div class="code-example-tablist" role="tablist" aria-label={ariaLabel}>
      {tabs.map((tab, index) => (
        <button
          type="button"
          class="code-example-tab"
          id={`${id}-tab-${tab.id}`}
          role="tab"
          aria-controls={`${id}-panel-${tab.id}`}
          aria-selected={index === 0 ? 'true' : 'false'}
          tabindex={index === 0 ? '0' : '-1'}
          data-tab-label={tab.label.toLowerCase()}
        >
          {tab.label}
        </button>
      ))}
    </div>

    <button
      type="button"
      class="code-example-copy"
      data-copy-button
    >
      {`Copy ${firstTab.label.toLowerCase()}`}
    </button>
  </div>

  {tabs.map((tab, index) => (
    <section
      class="code-example-panel"
      id={`${id}-panel-${tab.id}`}
      role="tabpanel"
      aria-labelledby={`${id}-tab-${tab.id}`}
      data-tab-panel
      data-tab-label={tab.label.toLowerCase()}
      data-language={tab.language}
      hidden={index !== 0}
    >
      <div class="code-example-render">
        <Code code={tab.code} lang={tab.language.toLowerCase()} theme="github-dark" />
      </div>
      <p class="code-example-description">{tab.description}</p>
      {showDownloads && (tab.downloadHref || bundleHref) && (
        <div class="code-example-links">
          <a href={resolveHref(tab.downloadHref)} class="code-example-link" download={tab.downloadLabel}>
            {`Download ${tab.downloadLabel}`}
          </a>
          {bundleHref && (
            <a href={resolveHref(bundleHref)} class="code-example-link" download={bundleLabel}>
              {`Download ${bundleLabel}`}
            </a>
          )}
        </div>
      )}
    </section>
  ))}
</div>

<script>
  const readyAttribute = 'data-code-example-tabs-ready';

  function fallbackCopy(text) {
    const textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.setAttribute('readonly', 'true');
    textarea.style.position = 'absolute';
    textarea.style.left = '-9999px';
    document.body.appendChild(textarea);
    textarea.select();

    try {
      document.execCommand('copy');
    } finally {
      textarea.remove();
    }
  }

  async function copyText(text) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      await navigator.clipboard.writeText(text);
      return;
    }

    fallbackCopy(text);
  }

  function updateCopyLabel(button, panel, prefix) {
    if (!button || !panel) {
      return;
    }

    button.textContent = `${prefix} ${panel.dataset.tabLabel}`;
  }

  document.querySelectorAll('[data-code-example-tabs]').forEach((container) => {
    if (container.hasAttribute(readyAttribute)) {
      return;
    }

    container.setAttribute(readyAttribute, 'true');

    const tabs = Array.from(container.querySelectorAll('[role="tab"]'));
    const panels = Array.from(container.querySelectorAll('[data-tab-panel]'));
    const copyButton = container.querySelector('[data-copy-button]');
    let copyResetTimer;

    const setActiveTab = (nextTab, focusTab = false) => {
      tabs.forEach((tab, index) => {
        const isActive = tab === nextTab;
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
        tab.setAttribute('tabindex', isActive ? '0' : '-1');
        panels[index].hidden = !isActive;
      });

      if (focusTab) {
        nextTab.focus();
      }

      const activePanel = panels.find((panel) => !panel.hidden);
      updateCopyLabel(copyButton, activePanel, 'Copy');
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => {
        setActiveTab(tab);
      });

      tab.addEventListener('keydown', (event) => {
        const lastIndex = tabs.length - 1;
        let nextIndex = index;

        if (event.key === 'ArrowRight') {
          nextIndex = index === lastIndex ? 0 : index + 1;
        } else if (event.key === 'ArrowLeft') {
          nextIndex = index === 0 ? lastIndex : index - 1;
        } else if (event.key === 'Home') {
          nextIndex = 0;
        } else if (event.key === 'End') {
          nextIndex = lastIndex;
        } else {
          return;
        }

        event.preventDefault();
        setActiveTab(tabs[nextIndex], true);
      });
    });

    copyButton?.addEventListener('click', async () => {
      const activePanel = panels.find((panel) => !panel.hidden);
      const code = activePanel?.querySelector('code')?.textContent ?? '';

      if (!code) {
        return;
      }

      try {
        await copyText(code);
        updateCopyLabel(copyButton, activePanel, 'Copied');
      } catch {
        copyButton.textContent = 'Copy failed';
      }

      window.clearTimeout(copyResetTimer);
      copyResetTimer = window.setTimeout(() => {
        const currentPanel = panels.find((panel) => !panel.hidden);
        updateCopyLabel(copyButton, currentPanel, 'Copy');
      }, 1400);
    });
  });
</script>

<style>
  .code-example-tabs {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }

  .code-example-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.75rem 0.85rem;
    border-bottom: 1px solid var(--border);
    background: rgba(255,255,255,0.02);
  }

  .code-example-tablist {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .code-example-tab,
  .code-example-copy {
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1;
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }

  .code-example-tab[aria-selected='true'] {
    color: var(--text);
    border-color: rgba(74,222,128,0.4);
    background: rgba(74,222,128,0.1);
  }

  .code-example-tab:hover,
  .code-example-copy:hover {
    color: var(--text);
    border-color: var(--border-hover);
  }

  .code-example-tab:focus-visible,
  .code-example-copy:focus-visible {
    outline: 2px solid var(--accent-py);
    outline-offset: 2px;
  }

  .code-example-panel {
    position: relative;
  }

  .code-example-panel::before {
    content: attr(data-language);
    position: absolute;
    top: 0.85rem;
    right: 1rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dim);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .code-example-render :global(pre) {
    margin: 0;
    padding: 1.35rem 1.1rem 1.15rem;
    overflow-x: hidden;
    background: transparent !important;
    border: 0;
  }

  .code-example-render :global(code) {
    display: block;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.7;
  }

  .code-example-render :global(.astro-code) {
    color: var(--text);
  }

  .code-example-description {
    margin: 0;
    padding: 0 1.1rem 1rem;
    color: var(--text-muted);
    font-size: 0.8rem;
    line-height: 1.55;
  }

  .code-example-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding: 0 1.1rem 1rem;
  }

  .code-example-link {
    color: var(--text-dim);
    text-decoration: none;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.35rem 0.65rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }

  .code-example-link:hover {
    color: var(--text);
    border-color: var(--border-hover);
    background: rgba(255,255,255,0.03);
  }

  .code-example-link:focus-visible {
    outline: 2px solid var(--accent-py);
    outline-offset: 2px;
  }

  .code-example-tabs.compact .code-example-toolbar {
    padding: 0.65rem 0.75rem;
  }

  .code-example-tabs.compact .code-example-tab,
  .code-example-tabs.compact .code-example-copy {
    font-size: 0.68rem;
    padding: 0.38rem 0.62rem;
  }

  .code-example-tabs.compact .code-example-panel::before {
    top: 0.75rem;
    right: 0.85rem;
    font-size: 0.64rem;
  }

  .code-example-tabs.compact .code-example-render :global(pre) {
    padding: 1.15rem 0.95rem 1rem;
  }

  .code-example-tabs.compact .code-example-render :global(code) {
    font-size: 0.76rem;
    line-height: 1.6;
  }

  .code-example-tabs.compact .code-example-description {
    padding: 0 0.95rem 0.9rem;
    font-size: 0.74rem;
  }

  .code-example-tabs.compact .code-example-links {
    padding: 0 0.95rem 0.9rem;
    gap: 0.5rem;
  }

  .code-example-tabs.compact .code-example-link {
    font-size: 0.64rem;
    padding: 0.32rem 0.58rem;
  }

  @media (max-width: 640px) {
    .code-example-toolbar {
      align-items: stretch;
      flex-direction: column;
    }

    .code-example-copy {
      align-self: flex-start;
    }

    .code-example-panel::before {
      position: static;
      display: block;
      padding: 0.85rem 1rem 0;
    }

    .code-example-render :global(pre) {
      padding-top: 0.55rem;
    }
  }
</style>