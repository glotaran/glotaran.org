---
interface Props {
  active?: 'legacy' | 'pyglotaran' | 'timp' | 'publications';
  communityHref?: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  active,
  communityHref = '/#community',
  ctaHref = 'https://pyglotaran.readthedocs.io',
  ctaLabel = 'Documentation ↗',
} = Astro.props;

const navItems = [
  { href: '/software/timp', label: 'TIMP', key: 'timp' },
  { href: '/software/glotaran-legacy', label: 'Glotaran 1.x', key: 'legacy' },
  { href: '/software/pyglotaran', label: 'pyglotaran', key: 'pyglotaran', emphasis: true },
  { href: '/publications', label: 'Publications', key: 'publications' },
  { href: communityHref, label: 'Community', key: 'community' },
] as const;
---

<nav>
  <a href="/" class="nav-logo">
    <span class="nav-logo-glo">Glo</span><span class="nav-logo-tar">Tar</span><span class="nav-logo-an">An</span>
  </a>
  <ul class="nav-links">
    {navItems.map((item) => (
      <li>
        <a
          href={item.href}
          class:list={{
            active: active === item.key,
            'nav-link-emphasis': item.emphasis,
          }}
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
  <a href={ctaHref} class="nav-cta" target="_blank" rel="noopener">{ctaLabel}</a>
</nav>

<style>
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2.5rem;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: rgba(12, 14, 18, 0.92);
    backdrop-filter: blur(12px);
    z-index: 100;
  }

  .nav-logo {
    display: flex;
    align-items: baseline;
    gap: 0.1em;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-logo-glo {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.4rem;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .nav-logo-tar {
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: 1.4rem;
    color: var(--text-muted);
  }

  .nav-logo-an {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.4rem;
    color: var(--text);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 400;
    transition: color 0.15s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--text);
  }

  .nav-link-emphasis {
    font-weight: 600;
    color: rgba(232, 234, 240, 0.94);
  }

  .nav-cta {
    background: transparent;
    border: 1px solid var(--border-hover);
    color: var(--text);
    padding: 0.45rem 1.1rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 400;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-cta:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.25);
  }

  @media (max-width: 1100px) {
    nav {
      padding: 1rem 1.5rem;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      column-gap: 1rem;
      row-gap: 0.85rem;
    }

    .nav-logo {
      grid-column: 1;
      grid-row: 1;
    }

    .nav-cta {
      grid-column: 3;
      grid-row: 1;
      justify-self: end;
    }

    .nav-links {
      grid-column: 1 / -1;
      grid-row: 2;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.75rem 1.35rem;
      padding-top: 0.85rem;
      border-top: 1px solid var(--border);
    }

    .nav-links a {
      font-size: 0.82rem;
    }

  }

  @media (max-width: 640px) {
    nav {
      padding: 1rem 1.25rem;
    }

    .nav-links {
      justify-content: flex-start;
      gap: 0.7rem 1rem;
    }

    .nav-links a {
      font-size: 0.78rem;
    }

    .nav-cta {
      padding: 0.38rem 0.8rem;
      font-size: 0.8rem;
    }
  }
</style>