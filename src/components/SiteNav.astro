---
interface Props {
  active?: 'legacy' | 'pyglotaran' | 'timp' | 'publications' | 'ecosystem' | 'community';
  isHome?: boolean;
  communityHref?: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const base = import.meta.env.BASE_URL;

const {
  active,
  isHome = false,
  communityHref = `${base}#community`,
  ctaHref = 'https://pyglotaran.readthedocs.io',
  ctaLabel = 'Documentation ↗',
} = Astro.props;

const navItems = [
  { href: `${base}software/timp`, label: 'TIMP', key: 'timp' },
  { href: `${base}software/glotaran-legacy`, label: 'Glotaran 1.x', key: 'legacy' },
  { href: `${base}software/pyglotaran`, label: 'pyglotaran', key: 'pyglotaran', emphasis: true },
  { href: `${base}publications`, label: 'Publications', key: 'publications' },
  { href: `${base}ecosystem`, label: 'Ecosystem', key: 'ecosystem' },
  { href: communityHref, label: 'Community', key: 'community' },
] as const;
---

<nav>
  <a href={base} class={`nav-logo ${isHome ? '' : 'collapsed'}`} id="sitenav-logo" data-home={isHome ? 'true' : 'false'}>
    <span class="logo-stack">
      <span class="logo-word">
        <span class="lr">Glo</span><span class="lx">bal </span><span class="lr">Tar</span><span class="lx">get </span><span class="lr">An</span><span class="lx">alysis</span>
      </span>
      <span class="logo-sub" id="logo-sub"></span>
    </span>
  </a>
  <ul class="nav-links">
    {navItems.map((item) => (
      <li>
        <a
          href={item.href}
          class:list={{
            active: active === item.key,
            'nav-link-emphasis': item.emphasis,
          }}
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
  <a href={ctaHref} class="nav-cta" target="_blank" rel="noopener">{ctaLabel}</a>
</nav>

<style>
  nav {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    column-gap: 1.5rem;
    padding: 1.25rem 2.5rem;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: rgba(12, 14, 18, 0.92);
    backdrop-filter: blur(12px);
    z-index: 100;
  }

  .nav-logo {
    display: inline-flex;
    align-items: baseline;
    gap: 0;
    text-decoration: none;
    flex-shrink: 0;
    justify-self: start;
    cursor: pointer;
  }

  .logo-stack {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .logo-word {
    display: inline-flex;
    align-items: baseline;
  }

  /* Root syllables: Glo · Tar · An */
  .nav-logo .lr {
    font-family: var(--font-display);
    font-weight: 600;
    font-style: normal;
    font-size: 1.4rem;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--accent-py);
    text-shadow: 0 0 16px rgba(79, 195, 247, 0.42);
    transition: color 0.4s ease, text-shadow 0.4s ease;
  }

  /* Extension syllables: bal · get · alysis — slide in/out */
  .nav-logo .lx {
    font-family: var(--font-display);
    font-weight: 300;
    font-style: normal;
    font-size: 1.4rem;
    letter-spacing: -0.015em;
    line-height: 1;
    color: var(--text-muted);
    overflow: hidden;
    white-space: nowrap;
    max-width: 6rem;
    opacity: 1;
  }

  /* Sub-label row */
  .logo-sub {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    overflow: hidden;
    max-height: 1.3em;
    opacity: 1;
    transition: max-height 0.35s ease 0.06s, opacity 0.3s ease 0.03s;
    white-space: nowrap;
    line-height: 1.3;
    margin-top: 0.15rem;
  }

  /* ── Collapse: R→L stagger ── */
  .nav-logo.collapsed .lr {
    color: var(--text-muted);
    text-shadow: none;
  }
  .nav-logo.collapsed .lx {
    max-width: 0;
    opacity: 0;
  }
  .nav-logo.collapsed .logo-sub {
    max-height: 0;
    opacity: 0;
    transition: max-height 0.25s ease 0s, opacity 0.2s ease 0s;
  }
  .nav-logo.collapsed .lx:nth-of-type(1) {
    transition: max-width 0.38s cubic-bezier(0.4, 0, 0.6, 1) 0.13s,
                opacity    0.28s ease 0.13s;
  }
  .nav-logo.collapsed .lx:nth-of-type(2) {
    transition: max-width 0.38s cubic-bezier(0.4, 0, 0.6, 1) 0.06s,
                opacity    0.28s ease 0.06s;
  }
  .nav-logo.collapsed .lx:nth-of-type(3) {
    transition: max-width 0.38s cubic-bezier(0.4, 0, 0.6, 1) 0s,
                opacity    0.28s ease 0s;
  }

  /* ── Expand: L→R stagger ── */
  .nav-logo:not(.collapsed) .lx:nth-of-type(1) {
    transition: max-width 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0s,
                opacity   0.38s ease 0s;
  }
  .nav-logo:not(.collapsed) .lx:nth-of-type(2) {
    transition: max-width 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.08s,
                opacity   0.38s ease 0.08s;
  }
  .nav-logo:not(.collapsed) .lx:nth-of-type(3) {
    transition: max-width 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.16s,
                opacity   0.38s ease 0.16s;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-logo .lx,
    .nav-logo .lr,
    .logo-sub { transition: none !important; }
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
    justify-self: center;
  }

  .nav-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 400;
    transition: color 0.15s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--text);
  }

  .nav-link-emphasis {
    font-weight: 600;
    color: rgba(232, 234, 240, 0.94);
  }

  .nav-cta {
    background: transparent;
    border: 1px solid var(--border-hover);
    color: var(--text);
    padding: 0.45rem 1.1rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 400;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    text-decoration: none;
    flex-shrink: 0;
    justify-self: end;
  }

  .nav-cta:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.25);
  }

  @media (max-width: 1100px) {
    nav {
      padding: 1rem 1.5rem;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      column-gap: 1rem;
      row-gap: 0.85rem;
    }

    .nav-logo {
      grid-column: 1;
      grid-row: 1;
    }

    .nav-cta {
      grid-column: 3;
      grid-row: 1;
      justify-self: end;
    }

    .nav-links {
      grid-column: 1 / -1;
      grid-row: 2;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.75rem 1.35rem;
      padding-top: 0.85rem;
      border-top: 1px solid var(--border);
    }

    .nav-links a {
      font-size: 0.82rem;
    }

  }

  @media (max-width: 640px) {
    nav {
      padding: 1rem 1.25rem;
    }

    .nav-links {
      justify-content: flex-start;
      gap: 0.7rem 1rem;
    }

    .nav-links a {
      font-size: 0.78rem;
    }

    .nav-cta {
      padding: 0.38rem 0.8rem;
      font-size: 0.8rem;
    }
  }
</style>

<script>
  const logo = document.getElementById('sitenav-logo');
  if (logo) {
    const isHome = logo.dataset.home === 'true';
    let collapseTimer: ReturnType<typeof setTimeout> | undefined;

    function collapse() {
      logo.classList.add('collapsed');
    }
    function expand() {
      logo.classList.remove('collapsed');
    }

    logo.addEventListener('mouseenter', () => {
      clearTimeout(collapseTimer);
      expand();
    });
    logo.addEventListener('mouseleave', () => {
      collapse();
    });

    if (isHome) {
      // Home: start expanded, auto-collapse after 1 s
      collapseTimer = setTimeout(collapse, 1000);
    }
    // Sub pages: already collapsed via class — hover only

    // Random sublabels
    const subs = [
      'time-resolved', 'spectroscopy', 'microscopy', 'kinetics',
      'lifetimes', 'SVD', 'Transient Absorption', 'Fluorescence',
      'Photophysics', 'EAS / DAS / SAS', 'Compartmental Models',
    ];
    const el = document.getElementById('logo-sub');
    if (el) {
      const picked: string[] = [];
      const pool = [...subs];
      for (let i = 0; i < 3 && pool.length; i++) {
        const idx = Math.floor(Math.random() * pool.length);
        picked.push(pool.splice(idx, 1)[0]);
      }
      el.textContent = picked.join(' · ');
    }
  }
</script>